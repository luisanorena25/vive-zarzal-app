{
  "name": "vive-zarzal-app",
  "version": "0.0.1",
  "description": "vive zarzal application",
  "keywords": [
    "nodejs",
    "sequelize",
    "express",
    "docker",
    "postgres"
  ],
  "homepage": "https://github.com/cristianco9/vive-zarzal-app.git)#readme",
  "bugs": {
    "url": "https://github.com/cristianco9/vive-zarzal-app.git)/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cristianco9/vive-zarzal-app.git).git"
  },
  "license": "MIT",
  "author": "Cristian Camilo <cristianco9>",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "dev-dep": "npm install && npm install nodemon morgan eslint eslint-config-prettier eslint-plugin-prettier prettier --save-dev -D",
    "env-var": "cp ./env/.envExample ./.env && echo \"environment variables injected\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "migrations:generate": "sequelize-cli migration:generate --name",
    "migrations:run": "sequelize-cli db:migrate",
    "migrations:revert": "sequelize-cli db:migrate:undo",
    "migrations:delete": "sequelize-cli db:migrate:undo:all"
  },
  "devDependencies": {
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "morgan": "^1.11.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "sequelize-cli": "^6.6.2"
  }
}
